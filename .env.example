# ==========================================
# ENLACEC - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# VERCEL DEPLOYMENT & ENTORNO LOCAL
# ==========================================

# ------------------------------------------
# 1. SERVICIOS DE INTELIGENCIA ARTIFICIAL (IA)
# ------------------------------------------
# GROQ_API_KEY: Clave principal para el Chatbot EnlaceC-Bot y Resúmenes Diarios (Llama 3.3 70B)
GROQ_API_KEY="tu_groq_api_key_aqui"

# GROK_API_KEY / XAI_API_KEY: Clave opcional de respaldo para modelos xAI Grok-2
GROK_API_KEY=""

# GEMINI_API_KEY: Clave opcional de respaldo para Google Gemini 3.5 Flash
GEMINI_API_KEY=""

# ------------------------------------------
# 2. BASE DE DATOS Y AUTENTICACIÓN (SUPABASE)
# ------------------------------------------
# VITE_SUPABASE_URL: URL de tu proyecto en Supabase (debe llevar prefijo VITE_ para el cliente React)
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"

# VITE_SUPABASE_ANON_KEY: Clave pública / Anon Key de tu proyecto en Supabase
VITE_SUPABASE_ANON_KEY="tu_anon_key_aqui"

# ------------------------------------------
# 3. ALMACENAMIENTO DE ARCHIVOS / BÓVEDA (CLOUDINARY)
# ------------------------------------------
# Para almacenamiento de comprobantes y facturas PDF en la nube
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ------------------------------------------
# 4. CONSULTA DE IDENTIDAD DNI (RENIEC / DECOLECTA)
# ------------------------------------------
# Token para consulta de DNI peruano en tiempo real con Decolecta API
DECOLECTA_RENIEC_TOKEN=""

# ------------------------------------------
# 5. CONFIGURACIÓN DEL SERVIDOR
# ------------------------------------------
# URL pública de la aplicación
APP_URL=""
